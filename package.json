{
  "name": "funni-farm",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "clean-next-cache": "node scripts/clean-next-cache.mjs",
    "verify-required-files": "node scripts/verify-required-files.mjs",
    "deployment-audit": "node scripts/deployment-audit.mjs",
    "predev": "npm run clean-next-cache && npm run verify-required-files",
    "dev": "next dev",
    "prebuild": "npm run clean-next-cache && npm run verify-required-files && npm run deployment-audit",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "next": "^15.5.19",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.5.19",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
